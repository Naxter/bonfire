# Copy this file to `.env` and fill in the values. `.env` is gitignored.

# --- Docker Compose (ignored by the native/systemd deploy) ---
# Change the ports if another project on the box already uses them.
# BACKEND_PORT=8000
# FRONTEND_PORT=3000
# NEXT_PUBLIC_API_URL=http://<pi-ip>:8000   # baked into the frontend at BUILD time
# TZ=Europe/Berlin
# SCRAPE_INTERVAL_SECONDS=3600     # how often to poll GMX for REWE eBons
# BACKUP_INTERVAL_SECONDS=86400    # how often to snapshot the SQLite DB

# --- LLM provider (item categorization, receipt structuring, meals, ask) ---
# JUST DROP IN A KEY: if you set OPENAI_API_KEY or GEMINI_API_KEY below, that
# provider is auto-detected — you don't need to set LLM_PROVIDER at all.
# To force one explicitly (e.g. local Ollama), uncomment: ollama | openai | gemini.
# LLM_PROVIDER=openai
# Verify a key works any time with:  python check_llm.py

# --- OpenAI (recommended for an always-on box — cloud, no local daemon) ---
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini             # cheap + multimodal (handles photos)
# OPENAI_VISION_MODEL=gpt-4o-mini      # defaults to OPENAI_MODEL

# --- Gemini (cloud, generous free tier) ---
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-2.0-flash        # cheap + multimodal
# GEMINI_VISION_MODEL=gemini-2.0-flash # defaults to GEMINI_MODEL

# --- Ollama (local only; not used unless selected / no cloud key present) ---
# OLLAMA_MODEL=gemma3:12b
# OLLAMA_HOST=http://<ollama-host>:11434
# OLLAMA_NUM_CTX=5000

# --- Telegram bot (photo intake, restock, budget, meals, ask) ---
# Create a bot with @BotFather, paste its token here. Message the bot once and it
# replies with your chat id; put that id below to lock the bot to you.
# TELEGRAM_BOT_TOKEN=123456:ABC-...
# TELEGRAM_ALLOWED_CHAT_IDS=123456789
# GROCERY_API_URL=http://localhost:8000

# --- Email scraper (GMX / REWE eBon) ---
GMX_USER=your_address@gmx.net
GMX_PASSWORD=your_app_password
GMX_IMAP_HOST=imap.gmx.net
REWE_SENDER=forwarder@example.com
# Subject filter for the IMAP search (default matches a forwarded eBon)
# REWE_SUBJECT=WG: Dein REWE eBon
# Display name for REWE receipts in the dashboard (e.g. your local market's name)
# REWE_STORE_NAME=REWE

# --- DM scraper ---
DM_BEARER_TOKEN=your_dm_access_token
# Saved "Meine eBons" overview page the scraper reads (default: dm.html)
# DM_HTML_FILE=dm.html
# Downloads land in backend/data/inbox/dm by default, where the watcher
# ingests them. Only override if you want the PDFs somewhere else.
# DM_DOWNLOAD_DIR=/path/elsewhere
